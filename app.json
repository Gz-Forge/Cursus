{
  "expo": {
    "name": "Cursus",
    "slug": "TablaApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gzforge.cursus",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gzforge.cursus",
      "permissions": ["android.permission.CAMERA"],
      "privacyPolicyUrl": "https://gz-forge.github.io/cursus-app/privacidad"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Cursus",
      "shortName": "Cursus",
      "description": "Gestión de materias universitarias",
      "themeColor": "#BB86FC",
      "backgroundColor": "#121212"
    },
    "extra": {
      "eas": {
        "projectId": "5be7cc96-1676-4ac7-95a1-5136ef2b0c42"
      }
    },
    "owner": "gzstudio"
  }
}
